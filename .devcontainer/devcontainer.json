{
  "name": "PyCon 2026 Shiny Workshop",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/rocker-org/devcontainer-features/quarto-cli:1": {
      "version": "1.10.3"
    }
  },
  "postCreateCommand": "python -m venv /home/vscode/.venv && /home/vscode/.venv/bin/pip install -r requirements.txt",
  "remoteEnv": {
    "PATH": "/home/vscode/.venv/bin:${containerEnv:PATH}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "quarto.quarto",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "posit.shiny"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/home/vscode/.venv/bin/python"
      }
    }
  },
  "forwardPorts": [8000, 4848],
  "portsAttributes": {
    "8000": {
      "label": "Shiny App",
      "onAutoForward": "notify"
    },
    "4848": {
      "label": "Quarto Preview",
      "onAutoForward": "notify"
    }
  }
}
